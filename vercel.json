{
  "builds": [{ "src": "backend/src/main.ts", "use": "@vercel/node" }],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/src/main.ts" },
    { "src": "/(.*)", "dest": "backend/src/main.ts" }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "DB_HOST": "@db_host",
    "DB_PORT": "@db_port",
    "DB_NAME": "@db_name",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "JWT_SECRET": "@jwt_secret",
    "ENCRYPTION_KEY": "@encryption_key"
  }
}